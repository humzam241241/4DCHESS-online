# ==================== SUPABASE ====================
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # Settings → API → service_role (secret)

# ==================== STRIPE ====================
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...           # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...         # Stripe Dashboard → Webhooks → signing secret

# Create two products in Stripe Dashboard → Products:
# 1. "Chaturaji Premium" — one-time $5 payment
# 2. "Chaturaji Monthly" — recurring subscription
STRIPE_LIFETIME_PRICE_ID=price_...      # one-time $5 price ID
STRIPE_MONTHLY_PRICE_ID=price_...       # monthly price ID

# ==================== APP ====================
FRONTEND_URL=https://chaturaji-4dchess.vercel.app   # used for Stripe redirect URLs
PORT=10000                                           # Render sets this automatically
NODE_ENV=production
